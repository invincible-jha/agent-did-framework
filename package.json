{
  "name": "@aumos/agent-did",
  "version": "0.1.0",
  "description": "W3C Decentralized Identifiers and Verifiable Credentials for AI agent trust attestation",
  "license": "BSL-1.1",
  "author": "MuVeraAI Corporation",
  "repository": {
    "type": "git",
    "url": "https://github.com/aumos-ai/agent-did-framework.git"
  },
  "homepage": "https://github.com/aumos-ai/agent-did-framework#readme",
  "bugs": {
    "url": "https://github.com/aumos-ai/agent-did-framework/issues"
  },
  "keywords": [
    "did",
    "decentralized-identifiers",
    "verifiable-credentials",
    "agent-identity",
    "w3c",
    "jwt",
    "ai-agents",
    "aumos"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src/credentials/schemas"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ examples/ --max-warnings 0",
    "lint:fix": "eslint src/ examples/ --fix",
    "format": "prettier --write src/ examples/",
    "format:check": "prettier --check src/ examples/",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0",
    "did-resolver": "^4.1.0",
    "jose": "^5.3.0",
    "multiformats": "^13.1.0",
    "varint": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/varint": "^6.0.1",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^7.0.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
